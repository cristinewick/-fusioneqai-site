#!/bin/bash
set -u

PROJECT_DIR="/Users/cristinewick/Documents/-fusioneqai-site"
TOOLS_DIR="$PROJECT_DIR/tools"
NODE="/Applications/Codex.app/Contents/Resources/node"

if [ ! -x "$NODE" ]; then
  for candidate in /opt/homebrew/bin/node /usr/local/bin/node "$(command -v node 2>/dev/null)"; do
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
      NODE="$candidate"
      break
    fi
  done
fi

if [ -z "$NODE" ] || [ ! -x "$NODE" ]; then
  osascript -e 'display dialog "Node.js was not found. Open Codex and ask it to run the renderer for you." buttons {"OK"} default button "OK" with icon caution'
  exit 1
fi

LOG_FILE="$(mktemp /tmp/fusioneq-clipboard-renderer-log.XXXXXX)"
CLIPBOARD_FILE="$(mktemp /tmp/fusioneq-clipboard-json.XXXXXX.txt)"

/usr/bin/pbpaste >"$CLIPBOARD_FILE"

if [ ! -s "$CLIPBOARD_FILE" ]; then
  osascript -e 'display dialog "Your clipboard is empty. Copy the GPT renderer-ready JSON first, then double-click this app again." buttons {"OK"} default button "OK" with icon caution'
  exit 1
fi

cd /tmp || exit 1

{
  echo "Cleaning clipboard JSON..."
  JSON_FILE="$("$NODE" "$TOOLS_DIR/clean_deal_readiness_json.js" "$CLIPBOARD_FILE")"
  echo "Saved cleaned JSON:"
  echo "$JSON_FILE"
  echo
  echo "Validating JSON..."
  "$NODE" "$TOOLS_DIR/validate_deal_readiness_json.js" "$JSON_FILE"
  echo
  echo "Rendering report..."
  "$NODE" "$TOOLS_DIR/render_deal_readiness_report.js" "$JSON_FILE"
} >"$LOG_FILE" 2>&1

STATUS=$?

if [ "$STATUS" -ne 0 ]; then
  osascript -e 'display dialog "The clipboard report did not render. Ask Codex to check the renderer log." buttons {"OK"} default button "OK" with icon caution' \
    -e "do shell script \"open -a TextEdit '$LOG_FILE'\""
  exit "$STATUS"
fi

PDF_PATH="$("$NODE" -e 'const fs=require("fs"); const path=require("path"); const file=process.argv[1]; const data=JSON.parse(fs.readFileSync(file,"utf8")); const base=data.fileName || path.basename(file, path.extname(file)); process.stdout.write(path.resolve("outputs/client-reports", `${base}.pdf`));' "$JSON_FILE")"

if [ -f "$PDF_PATH" ]; then
  open "$PDF_PATH"
  osascript -e 'display dialog "Deal Readiness Report rendered from clipboard and opened." buttons {"OK"} default button "OK" with icon note'
else
  osascript -e 'display dialog "Renderer finished, but the PDF was not found. Ask Codex to check outputs/client-reports." buttons {"OK"} default button "OK" with icon caution' \
    -e "do shell script \"open -a TextEdit '$LOG_FILE'\""
fi
